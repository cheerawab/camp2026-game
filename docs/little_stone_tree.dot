digraph LittleStoneEvolution {
  graph [
    rankdir=LR,
    splines=true,
    nodesep=0.55,
    ranksep=1.15,
    pad=0.3,
    bgcolor="white",
    pack=true,
    packmode="array_u6"
  ];

  node [
    shape=plain,
    fontname="Noto Sans CJK TC",
    fontsize=12
  ];

  edge [
    fontname="Noto Sans CJK TC",
    fontsize=11
  ];
  // =========================
  // 活動限定小石
  // =========================
  subgraph cluster_event_limited {
    label="活動限定小石";
    color="#cccccc";
    style="rounded";

    stone_order_guardian [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_order_guardian.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>秩序守護者小石</TD></TR>
      </TABLE>>
    ];
    stone_freedom_rebel [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_freedom_rebel.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>自由反抗者小石</TD></TR>
      </TABLE>>
    ];
    stone_python_turtle [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_python_turtle.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>烏龜小石</TD></TR>
      </TABLE>>
    ];
    stone_fireside [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_fireside.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>爐邊小石</TD></TR>
      </TABLE>>
    ];

    stone_command_blind_trip [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_command_blind_trip.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>指令盲旅小石</TD></TR>
      </TABLE>>
    ];
    stone_human_llm [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_human_llm.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>人類大語言模型小石</TD></TR>
      </TABLE>>
    ];
    stone_von_neumann [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_von_neumann.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>馮紐曼小石</TD></TR>
      </TABLE>>
    ];
    stone_packet_rescue [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_packet_rescue.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>封包救援小石</TD></TR>
      </TABLE>>
    ];
    stone_prompt_injection [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_prompt_injection.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>Prompt Injection 小石</TD></TR>
      </TABLE>>
    ];

    stone_order_guardian -> stone_freedom_rebel [style=invis, weight=10];
    stone_freedom_rebel -> stone_python_turtle [style=invis, weight=10];
    stone_python_turtle -> stone_fireside [style=invis, weight=10];
    stone_fireside -> stone_command_blind_trip [style=invis, weight=10];
    stone_command_blind_trip -> stone_human_llm [style=invis, weight=10];
    stone_human_llm -> stone_von_neumann [style=invis, weight=10];
    stone_von_neumann -> stone_packet_rescue [style=invis, weight=10];
    stone_packet_rescue -> stone_prompt_injection [style=invis, weight=10];
  }

  // =========================
  // 探索型小石
  // =========================
  subgraph cluster_explore {
    label="探索型小石";
    color="#cccccc";
    style="rounded";

    basic_gray [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/basic_gray.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>探索型小石</TD></TR>
      </TABLE>>
    ];

    stone_2022_maze [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2022_maze.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2022 迷宮小石</TD></TR>
      </TABLE>>
    ];
    stone_2022_break_wall_cat [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2022_break_wall_cat.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2022 破牆貓小石</TD></TR>
      </TABLE>>
    ];

    stone_camp_backpack [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_camp_backpack.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>營地背包小石</TD></TR>
      </TABLE>>
    ];
    stone_2026_camp_explorer [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2026_camp_explorer.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2026 營地探險小石</TD></TR>
      </TABLE>>
    ];

    stone_booth [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_booth.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>攤位小石</TD></TR>
      </TABLE>>
    ];
    stone_star_village_guide [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_star_village_guide.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>星手村嚮導小石</TD></TR>
      </TABLE>>
    ];

    stone_2019_blackbox [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2019_blackbox.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2019 黑箱小石</TD></TR>
      </TABLE>>
    ];
    stone_2019_unboxed_algorithm [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2019_unboxed_algorithm.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2019 開箱演算法小石</TD></TR>
      </TABLE>>
    ];

    basic_gray -> stone_2022_maze [label="迷宮地圖"];
    stone_2022_maze -> stone_2022_break_wall_cat [label="貓掌印"];

    basic_gray -> stone_camp_backpack [label="冒險背包"];
    stone_camp_backpack -> stone_2026_camp_explorer [label="任務地圖"];

    basic_gray -> stone_booth [label="攤位貼紙"];
    stone_booth -> stone_star_village_guide [label="星手村路標"];

    basic_gray -> stone_2019_blackbox [label="黑箱貼紙"];
    stone_2019_blackbox -> stone_2019_unboxed_algorithm [label="工具箱鑰匙"];

    {
      rank=same;
      stone_2022_maze;
      stone_camp_backpack;
      stone_booth;
      stone_2019_blackbox;
    }
    {
      rank=same;
      stone_2022_break_wall_cat;
      stone_2026_camp_explorer;
      stone_star_village_guide;
      stone_2019_unboxed_algorithm;
    }
  }

  // =========================
  // 靈光型小石
  // =========================
  subgraph cluster_inspiration {
    label="靈光型小石";
    color="#cccccc";
    style="rounded";

    basic_yellow [
