APP_ENV=local
SERVICE_NAME=camp2026-game-api
APP_VERSION=0.1.0
LOG_LEVEL=debug

HTTP_ADDR=:8080
REQUEST_TIMEOUT=10s
HTTP_READ_HEADER_TIMEOUT=5s
