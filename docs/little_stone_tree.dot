    stone_p5js [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_p5js.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>p5.js 小石</TD></TR>
      </TABLE>>
    ];
    stone_tech_art [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_tech_art.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>科技藝術小石</TD></TR>
      </TABLE>>
    ];

    stone_espresso [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_espresso.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>Espresso 小石</TD></TR>
      </TABLE>>
    ];

    stone_2024_ribbon [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2024_ribbon.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2024 彩帶小石</TD></TR>
      </TABLE>>
    ];
    stone_2024_last_night_polaroid [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2024_last_night_polaroid.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2024 最後一晚拍立得小石</TD></TR>
      </TABLE>>
    ];

    basic_orange -> stone_microphone [label="麥克風"];
    stone_microphone -> stone_lightning_talk [label="閃電講稿"];

    basic_orange -> stone_p5js [label="畫布程式碼"];
    stone_p5js -> stone_tech_art [label="像素顏料"];

    basic_orange -> stone_espresso [label="Espresso 杯"];

    basic_orange -> stone_2024_ribbon [label="彩帶"];
    stone_2024_ribbon -> stone_2024_last_night_polaroid [label="拍立得底片"];

    { rank=same; stone_microphone; stone_p5js; stone_espresso; stone_2024_ribbon; }
    { rank=same; stone_lightning_talk; stone_tech_art; stone_2024_last_night_polaroid; }
  }
}
