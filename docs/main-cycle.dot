strict digraph {

  bgcolor="white";
  splines=spline;
  nodesep=0.8;
  ranksep=1.1;

  concentrate=true;

  graph [
    fontname="Noto Sans CJK TC",
    labelloc="t",
    label="小石開源力：知識探索核心循環"
  ];

  node [
    fontname="Noto Sans CJK TC",
    shape=box,
    style="rounded,filled",
    color="#333333",
    fillcolor="#F8F8F8",
    margin="0.3,0.3"
  ];

  edge [
    fontname="Noto Sans CJK TC",
    color="#333333",
    arrowsize=0.8
  ];

  // ===== 中心資產 =====

  ProfileBase [
    label="基地主頁\n小石、佈景、回顧展示",
    fillcolor="#D9EAD3",
    fontsize=18
  ];

  Inventory [
    label="收藏背包\n開源力、道具、小石造型",
    fillcolor="#FCE5CD"
  ];

  // ===== 行為輸入 =====

  RealActions [
    label="營隊實際行為\n提問、互動、協助、解題、參與活動",
    fillcolor="#F4CCCC",
    fontcolor="#CC0000"
  ];

  ActionReward [
    label="取得對應小石\n開源力、造型道具、基地佈景",
    fillcolor="#F4CCCC"
  ];

  // ===== 知識王 =====

  Quiz [
    label="知識王\nCP 訂正、面對面對戰",
    fillcolor="#D9EAF7",
    fontcolor="#1C4587"
  ];

  Explanation [
    label="看解析\n答錯進訂正區",
    fillcolor="#D9EAF7"
  ];

  QuizReward [
    label="題組紀錄\n開源力、道具、小石",
    fillcolor="#D9EAF7"
  ];

  // ===== 合成與展示 =====

  Craft [
    label="造型合成\n小石 + 指定道具",
    fillcolor="#FFF2CC"
  ];

  NewStyle [
    label="新造型小石\n行為紀念與展示",
    fillcolor="#FFF2CC"
  ];

  BaseTheme [
    label="套用基地佈景\n主頁就是基地",
    fillcolor="#D9EAD3"
  ];

  // ===== 世界魔王 =====

  DailyCourse [
    label="當天課程內容\n形成魔王題組",
    fillcolor="#EADCF8"
  ];

  WorldBoss [
    label="全營世界魔王\n共同推進階段",
    fillcolor="#EADCF8",
    fontcolor="#3366CC"
  ];

  BossClear [
    label="共鬥勝利\n全體參與者獲得限定造型小石",
    fillcolor="#EADCF8",
    fontcolor="#3366CC"
  ];

  // ===== 收束 =====

  Review [
    label="Day 5 活動回顧\n多類型成就結算",
    fillcolor="#EFEFEF",
    fontcolor="#3366CC"
  ];

  Awards [
    label="實體獎勵與紀念\n知識、訂正、合作、探索、收藏",
    fillcolor="#EFEFEF"
  ];

  // ===== 主循環 =====

  RealActions -> ActionReward [label="完成後"];
  ActionReward -> Inventory [label="加入收藏"];
  ActionReward -> ProfileBase [label="更新展示"];

  Inventory -> Craft [label="使用道具"];
  Craft -> NewStyle [label="合成"];
  NewStyle -> Inventory [label="加入背包"];
  NewStyle -> ProfileBase [label="展示"];

  Inventory -> BaseTheme [label="兌換佈景"];
  BaseTheme -> ProfileBase [label="套用"];

  Quiz -> Explanation [label="作答後"];
  Explanation -> QuizReward [label="答對或完成訂正"];
  QuizReward -> Inventory [label="取得獎勵"];
  QuizReward -> ProfileBase [label="留下紀錄"];

  DailyCourse -> WorldBoss [label="每日題組"];
  QuizReward -> WorldBoss [label="推進共同進度"];
  RealActions -> WorldBoss [label="任務貢獻"];
  WorldBoss -> BossClear [label="階段擊破"];
  BossClear -> Inventory [label="限定造型"];
  BossClear -> ProfileBase [label="魔王紀念"];

  ProfileBase -> Review [label="累積回顧素材"];
  Inventory -> Review [label="收藏紀錄"];
  WorldBoss -> Review [label="參與階段"];
  Review -> Awards [label="Day 5 結算"];
}
