        <TR><TD>靈光型小石</TD></TR>
      </TABLE>>
    ];

    stone_2021_abacus [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2021_abacus.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2021 算盤小石</TD></TR>
      </TABLE>>
    ];
    stone_2021_abacus_descendant [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2021_abacus_descendant.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2021 算盤後裔小石</TD></TR>
      </TABLE>>
    ];

    stone_prompt [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_prompt.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>Prompt 小石</TD></TR>
      </TABLE>>
    ];
    stone_human_after_all [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_human_after_all.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>Human After All 小石</TD></TR>
      </TABLE>>
    ];

    stone_sticky_note [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_sticky_note.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>便利貼小石</TD></TR>
      </TABLE>>
    ];
    stone_course_shared_notes [
