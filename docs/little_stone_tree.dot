        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_course_shared_notes.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>課程共筆小石</TD></TR>
      </TABLE>>
    ];

    stone_2024_finite [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2024_finite.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2024 有限小石</TD></TR>
      </TABLE>>
    ];
    stone_2024_infinite_inspiration [
      label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0">
        <TR><TD FIXEDSIZE="TRUE" WIDTH="92" HEIGHT="92"><IMG SRC="../frontend/public/game-icons/stones/stone_2024_infinite_inspiration.png" SCALE="TRUE"/></TD></TR>
        <TR><TD>2024 無限靈感小石</TD></TR>
      </TABLE>>
    ];

    basic_yellow -> stone_2021_abacus [label="木製算珠"];
    stone_2021_abacus -> stone_2021_abacus_descendant [label="前人筆記"];

    basic_yellow -> stone_prompt [label="Prompt 卡"];
    stone_prompt -> stone_human_after_all [label="人類標籤"];

    basic_yellow -> stone_sticky_note [label="便利貼"];
    stone_sticky_note -> stone_course_shared_notes [label="共筆連結"];

    basic_yellow -> stone_2024_finite [label="有限標籤"];
    stone_2024_finite -> stone_2024_infinite_inspiration [label="無限星圖"];

    {
      rank=same;
      stone_2021_abacus;
      stone_prompt;
      stone_sticky_note;
      stone_2024_finite;
    }
    {
      rank=same;
      stone_2021_abacus_descendant;
      stone_human_after_all;
      stone_course_shared_notes;
      stone_2024_infinite_inspiration;
    }
  }

  // =========================
  // 共鳴型小石
  // =========================
  subgraph cluster_resonance {
    label="共鳴型小石";
    color="#cccccc";
