    basic_purple -> stone_community_handshake [label="學生社群卡"];
    stone_community_handshake -> stone_star_village_exchange [label="星手村徽章"];

    basic_purple -> stone_consensus_draft [label="章程草稿"];
    stone_consensus_draft -> stone_student_autonomy [label="透明提案"];

    basic_purple -> stone_contribution [label="貢獻貼紙"];
    stone_contribution -> stone_open_source_route [label="開源路線圖"];

    basic_purple -> stone_2020_tour_flag [label="導遊旗"];
    stone_2020_tour_flag -> stone_2020_sitcon_tour_group [label="會場路線"];

    {
